# Скопируй этот файл в .env.local и заполни своими значениями

# ── Telegram Bot ──────────────────────────────────────────────
# 1. Напиши @BotFather → /newbot → получи токен
# 2. Напиши своему боту любое сообщение
# 3. Открой https://api.telegram.org/bot<TOKEN>/getUpdates
#    → найди "chat":{"id": ...} — это твой CHAT_ID
VITE_TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_TELEGRAM_CHAT_ID=123456789

# ── Supabase (опционально, для админки) ───────────────────────
# Найти в: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...
